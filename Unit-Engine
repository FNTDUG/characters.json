<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Audiowide&display=swap" rel="stylesheet">

      <style>
      
      #unitEngine,
      #unitEngine * {
        font-family: 'Press Start 2P', cursive !important;
      }
        
      #unitEngine h2,
      #unitEngine h3 {
        font-family: 'Audiowide', sans-serif !important;
      }

      
      #unitEngine {
        --ue-bg:       #08080f;
        --ue-panel:    rgba(12, 9, 24, 0.94);
        --ue-glass:    rgba(14, 11, 28, 0.88);
        --ue-accent:   #ffa45b;
        --ue-purple:   #681f62;
        --ue-border:   rgba(255, 164, 91, 0.55);
        --ue-glow:     rgba(139, 31, 132, 0.6);
        --ue-r:        14px;
        --ue-r-sm:     9px;
      }

      
      #unitEngine {
        background-color: var(--ue-bg);
        background-image:
          repeating-linear-gradient(
            to bottom,
            transparent 0px,
            transparent 3px,
            rgba(0, 0, 0, 0.07) 3px,
            rgba(0, 0, 0, 0.07) 4px
          );
        color: white;
        padding: 0;
        border-radius: 18px;
        max-width: 650px;
        width: 95%;
        margin: 30px auto;
        box-shadow:
          0 0 0 1px rgba(255, 164, 91, 0.2),
          0 0 35px 8px rgba(104, 31, 98, 0.55),
          0 0 70px 20px rgba(104, 31, 98, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.04);
        border: 2px solid var(--ue-accent);
        box-sizing: border-box;
        position: relative;
      }

      
      #unitEngine::before {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          to bottom,
          transparent 0px,
          transparent 3px,
          rgba(0, 0, 0, 0.06) 3px,
          rgba(0, 0, 0, 0.06) 4px
        );
        pointer-events: none;
        z-index: 900;
        border-radius: inherit;
      }

      
      #unitEngine .ue-header {
        background: linear-gradient(180deg,
          #120326 0%,
          #3a0a38 30%,
          #681f62 55%,
          #3a0a38 78%,
          #120326 100%
        );
        text-align: center;
        padding: 26px 48px 22px;
        position: relative;
        border-bottom: 2px solid var(--ue-accent);
        overflow: hidden;
        border-radius: 16px 16px 0 0;
      }

      
      #unitEngine .ue-header::before,
      #unitEngine .ue-header::after {
        content: '◆';
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        font-size: 16px;
        color: var(--ue-accent);
        opacity: 0.55;
        font-family: 'Press Start 2P', cursive !important;
        pointer-events: none;
      }
      #unitEngine .ue-header::before { left: 14px; }
      #unitEngine .ue-header::after  { right: 14px; }

      #unitEngine .ue-header h2 {
        font-size: 34px;
        margin: 0;
        color: #fff;
        text-shadow:
          0 0 6px var(--ue-accent),
          0 0 18px rgba(255, 164, 91, 0.45),
          0 0 38px rgba(255, 164, 91, 0.18);
        letter-spacing: 2px;
      }

      
      #engineInner {
        padding: 20px;
        position: relative;
      }

      
      #unitEngine .ue-search-wrap {
        position: relative;
      }
        
      #result {
        margin-top: 20px;
      }
      #result > div {
        margin: 0 auto;
      }

      
      #unitEngine table {
        width: 100% !important;
        border-collapse: collapse !important;
        margin: 0 !important;
      }

      #unitEngine table th,
      #unitEngine table td {
        text-align: center !important;
        vertical-align: middle !important;
        padding: 7px 6px !important;
        border-bottom: 1px solid rgba(255, 164, 91, 0.3) !important;
        white-space: nowrap !important;
        line-height: 1.4 !important;
      }

      #unitEngine .ue-dps-row td {
        line-height: 2 !important;
        padding-top: 5px !important;
      }

      #unitEngine table th {
        background: rgba(104, 31, 98, 0.35);
        color: #ffa45b;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.4px;
      }

      #unitEngine table th:not(:last-child),
      #unitEngine table td:not(:last-child) {
        border-right: 1px solid rgba(255, 164, 91, 0.2) !important;
      }

      #unitEngine table tr:last-child td {
        border-bottom: none !important;
      }

      
      .ue-element-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        gap: 5px;
        white-space: nowrap;
        line-height: 1;
      }

      #unitEngine .ue-element-icon {
        width: 1.3em !important;
        height: 1.3em !important;
        flex-shrink: 0 !important;
        display: block !important;
        vertical-align: middle !important;
      }

      
      #unitEngine .buff-tabs-card {
        margin-top: 14px;
        border: 1px solid rgba(255, 164, 91, 0.4);
        border-radius: 12px;
        background: var(--ue-panel);
        color: #fff;
        overflow: hidden;
        background-clip: padding-box;
        box-sizing: border-box;
      }

      #unitEngine .buff-tabs-header {
        display: flex;
        border-bottom: 1px solid rgba(255, 164, 91, 0.35);
        background: linear-gradient(90deg, #120324, #3a0a38, #120324);
        border-top-left-radius: 11px;
        border-top-right-radius: 11px;
      }

      #unitEngine .buff-tab-btn {
        flex: 1;
        padding: 9px 4px;
        font-size: 10px;
        text-transform: uppercase;
        text-align: center;
        border: none;
        border-right: 1px solid rgba(255, 164, 91, 0.2);
        background: transparent;
        color: rgba(255, 255, 255, 0.5);
        cursor: pointer;
        letter-spacing: 0.4px;
        transition: background 0.15s, color 0.15s;
      }

      #unitEngine .buff-tab-btn:last-child {
        border-right: none;
      }

      #unitEngine .buff-tab-btn + .buff-reset-btn {
        border-left: none;
      }

      #unitEngine .buff-reset-btn {
        flex: 0 0 auto;
        width: 34px;
        padding: 0;
        font-size: 16px;
        text-align: center;
        border: none;
        border-left: 1px solid rgba(255, 164, 91, 0.2);
        background: transparent;
        color: rgba(255, 164, 91, 0.65);
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        border-top-right-radius: 11px;
      }
      #unitEngine .buff-reset-btn:hover {
        background: rgba(255, 164, 91, 0.1);
        color: #fff;
      }

      #unitEngine .buff-tab-btn.active {
        color: var(--ue-accent);
        box-shadow: inset 0 -2px 0 var(--ue-accent);
        background: rgba(104, 31, 98, 0.3);
      }

      #unitEngine .buff-tab-btn:not(.active):hover {
        background: rgba(255, 164, 91, 0.07);
        color: rgba(255, 255, 255, 0.8);
      }

      #unitEngine .buff-tabs-body {
        padding: 10px 10px 12px;
        font-size: 11px;
      }

      #unitEngine .buff-panel-label {
        font-size: 10px;
        opacity: 0.65;
        margin-top: 2px;
        margin-bottom: 2px;
      }

      #unitEngine .buff-select {
        width: 100%;
        margin-top: 3px;
        padding: 6px 8px;
        border-radius: 8px;
        border: 1px solid rgba(255, 164, 91, 0.4);
        background-color: rgba(8, 6, 18, 0.9);
        color: #fff;
        font-size: 10px;
        box-sizing: border-box;
        outline: none;
        transition: border-color 0.15s;
      }

      #unitEngine .buff-select:focus {
        border-color: var(--ue-accent);
      }

      #unitEngine .buff-stack-wrap {
        margin-top: 8px;
      }

      #unitEngine .buff-summary {
        margin-top: 8px;
        font-size: 10px;
        text-align: center;
        opacity: 0.9;
        line-height: 1.25;
        color: var(--ue-accent);
      }
        
      
      #unitEngine .unit-table-container,
      #unitEngine .unit-info-box,
      #unitEngine .dps-box {
        padding: 0 !important;
        border: 1px solid rgba(255, 164, 91, 0.4) !important;
        border-radius: 10px !important;
        overflow: hidden;
      }

      .unit-table-container {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        box-sizing: border-box;
        position: relative;
        padding-bottom: 1px;
      }

      #unitEngine .ue-scroll-wrap {
        white-space: nowrap;
      }

      .unit-info-table table th,
      .unit-info-table table td {
        border-bottom: 1px solid rgba(255, 164, 91, 0.3) !important;
      }
      .unit-info-table table th:not(:last-child),
      .unit-info-table table td:not(:last-child) {
        border-right: 1px solid rgba(255, 164, 91, 0.2) !important;
      }

      #result img {
        max-width: 100%;
        height: auto;
      }

      
      @media (max-width: 768px) {
        #unitEngine .ue-scroll-wrap {
          overflow-x: hidden !important;
          overflow-y: hidden !important;
          display: block !important;
          width: 100% !important;
        }

        #unitEngine .unit-table-container {
          overflow-x: auto !important;
          overflow-y: hidden !important;
          -webkit-overflow-scrolling: touch;
          overscroll-behavior-x: contain;
          scrollbar-width: thin;
          scrollbar-color: rgba(255, 164, 91, 0.45) transparent;
        }
        #unitEngine .unit-table-container::-webkit-scrollbar { height: 4px; }
        #unitEngine .unit-table-container::-webkit-scrollbar-thumb {
          background: rgba(255, 164, 91, 0.5);
          border-radius: 2px;
        }
        #unitEngine .unit-table-container::-webkit-scrollbar-track {
          background: transparent;
        }
      }

      @media (min-width: 769px) {
        #unitEngine .ue-scroll-wrap {
          overflow-x: visible !important;
        }
      }

      
      #ueValueDemand {
        width: 100%;
        max-width: 280px;
        margin: 10px auto 12px auto;
      }

      .ue-vd-outer {
        padding: 2px;
        border-radius: 12px;
        box-sizing: border-box;
      }

      .ue-vd-inner {
        border-radius: 10px;
        overflow: hidden;
        box-sizing: border-box;
        background-color: rgba(34,34,34,0.85);
        transition: background-color 0.25s ease;
      }

      .ue-vd-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      .ue-vd-col {
        padding: 12px 10px;
        text-align: center;
        box-sizing: border-box;
      }

      .ue-vd-col + .ue-vd-col {
        border-left: 1px solid rgba(255,255,255,0.12);
      }

      .ue-vd-title {
        font-size: 12px;
        opacity: 0.85;
        margin-bottom: 6px;
      }

      .ue-vd-value {
        font-size: 14px;
        font-weight: 700;
      }

      
      #unitSearch {
        width: 100%;
        padding: 13px 14px;
        font-size: 16px;
        line-height: 1.3;

        border-radius: 10px;
        border: 2px solid rgba(255, 164, 91, 0.5);
        background: rgba(8, 6, 18, 0.92);
        color: white;

        display: block;
        margin-top: 12px;
        box-sizing: border-box;

        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
      }

      #unitSearch:focus {
        border-color: var(--ue-accent);
        box-shadow:
          0 0 0 2px rgba(255, 164, 91, 0.15),
          0 0 16px rgba(255, 164, 91, 0.18);
      }

      #unitSearch::placeholder {
        color: rgba(255, 255, 255, 0.3);
      }

      
      #unitEngine #categoryModeSelect,
      #unitEngine #categoryValueSelect,
      #unitEngine #categoryFilter,
      #unitEngine #rarityFilter,
      #unitEngine #elementFilter {
        width: 100% !important;
        box-sizing: border-box !important;

        background: rgba(8, 6, 18, 0.92) !important;
        color: #fff !important;

        border: 2px solid rgba(255, 164, 91, 0.45) !important;
        border-radius: 10px !important;

        padding: 10px 12px !important;
        margin: 0 0 6px 0 !important;

        font-size: 11px !important;
        line-height: 1.2 !important;

        outline: none !important;
        cursor: pointer !important;
        transition: border-color 0.2s, box-shadow 0.2s !important;

        appearance: none !important;
        -webkit-appearance: none !important;
        -moz-appearance: none !important;
        background-image: none !important;
        padding-right: 12px !important;
      }

      #unitEngine #categoryModeSelect:focus,
      #unitEngine #categoryValueSelect:focus,
      #unitEngine #categoryFilter:focus,
      #unitEngine #rarityFilter:focus,
      #unitEngine #elementFilter:focus {
        border-color: var(--ue-accent) !important;
        box-shadow: 0 0 0 2px rgba(255, 164, 91, 0.15), 0 0 12px rgba(255, 164, 91, 0.15) !important;
      }

      #unitEngine #categoryModeSelect option,
      #unitEngine #categoryValueSelect option,
      #unitEngine #categoryFilter option,
      #unitEngine #rarityFilter option,
      #unitEngine #elementFilter option {
        background: #0a0814 !important;
        color: #fff !important;
      }

      
      @keyframes shinyBorderLoop {
        0%   { background-position: 0% 50%; }
        100% { background-position: 200% 50%; }
      }

      
      #unitEngine .voice-box {
        width: 100%;
        box-sizing: border-box;
      }

      #unitEngine .voice-outer {
        padding: 2px;
        border-radius: 10px;
        border: 2px solid #ffa45b;
        background-color: #681f62;
        box-sizing: border-box;
      }

      #unitEngine .voice-shell {
        background-color: var(--ue-glass);
        border-radius: 8px;
        padding: 10px 12px;
        text-align: center;
        color: #fff;
        box-sizing: border-box;
      }

      #unitEngine .voice-title {
        font-size: 14px;
        margin-bottom: 6px;
      }

      #unitEngine .voice-btn {
        width: 100%;
        box-sizing: border-box;
        padding: 8px 0;
        border-radius: 8px;
        border: 2px solid rgba(255, 164, 91, 0.7);
        cursor: pointer;
        user-select: none;
        font-size: 14px;
        color: #fff;
        background-color: rgba(0, 0, 0, 0.35);
        transition: background-color 0.15s, border-color 0.15s;
      }

      #unitEngine .voice-btn:hover {
        background-color: rgba(255, 164, 91, 0.12);
        border-color: var(--ue-accent);
      }

      
      #unitEngine .ue-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.72);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        box-sizing: border-box;
      }

      #unitEngine .ue-modal {
        width: min(560px, 95vw);
        max-width: 400px;
        max-height: min(70vh, 520px);
        overflow: auto;
        background: rgba(10, 8, 22, 0.97);
        border: 2px solid rgba(255, 164, 91, 0.65);
        border-radius: 14px;
        box-shadow:
          0 0 50px rgba(0, 0, 0, 0.85),
          0 0 20px rgba(255, 164, 91, 0.08);
        position: relative;
        box-sizing: border-box;
      }

      #unitEngine .ue-modal-header {
        background: linear-gradient(90deg, #120324, #3a0a38, #120324);
        border-bottom: 1px solid rgba(255, 164, 91, 0.35);
        padding: 12px 14px;
        text-align: center;
        font-size: 12px;
        color: #fff;
      }

      #unitEngine .ue-modal-close {
        position: absolute;
        top: 8px;
        right: 10px;
        width: 28px;
        height: 28px;
        border-radius: 8px;
        border: 1px solid rgba(255, 164, 91, 0.5);
        background: rgba(58, 10, 56, 0.85);
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: Arial, sans-serif !important;
        font-size: 14px;
        line-height: 1;
        padding: 0;
        box-sizing: border-box;
        transition: background 0.15s, border-color 0.15s;
      }

      #unitEngine .ue-modal-close:hover {
        background: rgba(255, 164, 91, 0.2);
        border-color: var(--ue-accent);
      }

      @media (max-width: 420px) {
        #unitEngine .ue-modal-close {
          top: 6px;
          right: 6px;
          width: 26px;
          height: 26px;
          font-size: 13px;
        }
      }

      #unitEngine .ue-modal-body {
        padding: 12px 14px 14px;
      }

      #unitEngine .voice-line {
        border: 1px solid rgba(255, 164, 91, 0.3);
        border-radius: 10px;
        padding: 10px;
        margin-bottom: 10px;
        background: rgba(104, 31, 98, 0.15);
      }

      #unitEngine .voice-line-title {
        font-size: 11px;
        margin-bottom: 6px;
        color: #ffd27f;
        text-align: center;
      }

      #unitEngine .voice-audio {
        width: 100%;
      }

      
      @media (max-width: 768px) {
        #unitEngine .buff-tabs-card {
          overflow: hidden;
          background-clip: padding-box;
        }

        #unitEngine .buff-tabs-header {
          display: flex;
          flex-wrap: nowrap;
          overflow-x: auto !important;
          overflow-y: hidden !important;
          -webkit-overflow-scrolling: touch;
          white-space: nowrap;
          width: 100%;
          scrollbar-width: thin;
          scrollbar-color: rgba(255, 164, 91, 0.4) transparent;
        }

        #unitEngine .buff-tabs-header::-webkit-scrollbar { height: 3px; }
        #unitEngine .buff-tabs-header::-webkit-scrollbar-thumb {
          background: rgba(255, 164, 91, 0.5);
          border-radius: 2px;
        }

        #unitEngine .buff-tab-btn {
          flex: 0 0 auto !important;
          min-width: 120px;
          white-space: nowrap;
        }
      }
        
      
      #unitEngine #autocomplete {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        z-index: 9000;

        background: rgba(10, 7, 22, 0.97);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 10px;
        border: 2px solid rgba(255, 164, 91, 0.55);
        padding: 0;

        max-height: 150px;
        overflow-y: auto;
        overflow-x: hidden;

        display: none;
        box-shadow:
          0 10px 36px rgba(0, 0, 0, 0.75),
          0 0 16px rgba(255, 164, 91, 0.08);
        box-sizing: border-box;

        scrollbar-width: thin;
        scrollbar-color: rgba(255,164,91,0.4) transparent;
      }

      #unitEngine #autocomplete::-webkit-scrollbar { width: 4px; }
      #unitEngine #autocomplete::-webkit-scrollbar-thumb {
        background: rgba(255, 164, 91, 0.4);
        border-radius: 2px;
      }

      #unitEngine .ue-ac-count {
        padding: 6px 14px;
        font-size: 9px;
        color: rgba(255, 164, 91, 0.85);
        border-bottom: 1px solid rgba(255, 164, 91, 0.2);
        text-align: center;
        letter-spacing: 2px;
        background: #1a0530;
        border-radius: 8px 8px 0 0;
        position: sticky;
        top: 0;
      }

      #unitEngine .autocomplete-item {
        padding: 9px 14px;
        font-size: 12px;
        cursor: pointer;
        border-bottom: 1px solid rgba(255, 164, 91, 0.1);
        transition: background 0.15s;
        background: transparent;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #fff;
      }

      #unitEngine .autocomplete-item:last-child {
        border-bottom: none;
      }

      #unitEngine .autocomplete-item:hover {
        background: rgba(104, 31, 98, 0.35);
      }

      .ue-info-table td {
        text-align: center;
      }

      @media (max-width: 768px) {
        .ue-info-table td,
        .ue-info-table th {
          box-sizing: border-box;
          min-width: 0;
        }
      }

      
      .arrow {
        display: inline-block;
        transition: transform 0.3s;
      }

      
      #ueValueDemandInner {
        background-color: rgba(34,34,34,0.85);
        transition: background-color 0.25s ease;
      }

      #ueValueDemandInner.vd-stable {
        background-color: rgba(70, 110, 140, 0.85) !important;
      }

      #ueValueDemandInner.vd-unstable {
        background-color: rgba(150, 95, 20, 0.85) !important;
      }

      #ueValueDemandInner.vd-hyped {
        background-color: rgba(120, 55, 85, 0.85) !important;
      }

      #ueValueDemandInner.vd-rising {
        background-color: rgba(45, 120, 45, 0.85) !important;
      }

      #ueValueDemandInner.vd-dropping {
        background-color: rgba(130, 45, 45, 0.85) !important;
      }

      #ueValueDemandInner.vd-manipulated {
        background-color: rgba(254, 165, 0, 0.85) !important;
      }

      #ueValueDemandInner.vd-underpaid {
        background-color: rgba(0, 180, 170, 0.85) !important;
      }
        
      #ueValueDemandInner.vd-fluctuating {
        background-color: rgba(128, 128, 128, 0.85) !important;
      }

      #ueValueDemandInner.vd-overpaid {
        background-color: rgba(208, 97, 199, 0.85) !important;
      }

      #ueValueDemandInner.vd-stable,
      #ueValueDemandInner.vd-unstable,
      #ueValueDemandInner.vd-hyped,
      #ueValueDemandInner.vd-rising,
      #ueValueDemandInner.vd-dropping,
      #ueValueDemandInner.vd-manipulated,
      #ueValueDemandInner.vd-underpaid,
      #ueValueDemandInner.vd-fluctuating,
      #ueValueDemandInner.vd-overpaid {
        box-shadow: inset 0 0 12px rgba(0,0,0,0.35);
      }

      
      .ue-tier-stars {
        display: flex;
        justify-content: center;
        gap: 2px;
        pointer-events: none;
      }

      .ue-tier-stars > div {
        display: flex;
        justify-content: center;
        gap: 2px;
      }

      .ue-tier-star {
        font-size: 13px;
        line-height: 1;
        color: #FFD54F;
        text-shadow: 0 0 6px rgba(255, 213, 79, 0.5);
      }

      .ue-tier-outer {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
      }

      .ue-tier-outer:hover {
        transform: translateY(-2px) scale(1.05);
      }
        
      
      .ue-exists-cell {
        text-align: center;
        overflow: visible !important;
      }

      .ue-exists-text {
        font-family: 'Audiowide', Arial, sans-serif !important;
        display: inline-block;
        font-weight: 600;
        color: #fff;
      }

      .ue-exists-shiny {
        color: transparent !important;
        background-image: linear-gradient(
          90deg,
          red,
          orange,
          yellow,
          lime,
          cyan,
          blue,
          magenta,
          red
        );
        background-size: 200% 200%;
        -webkit-background-clip: text;
        background-clip: text;
