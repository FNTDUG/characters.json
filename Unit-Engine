      function normalizeTypeTag(t) {
        t = String(t || "").trim().toLowerCase();
        if (t === "support") return "Support";
        if (t === "slow")    return "Slow";
        if (t === "stun")    return "Stun";
        if (t === "knockback")    return "Knockback";
        if (t === "wither")    return "Wither";
        if (t === "death")    return "Death";
        if (t === "income")  return "Income";
        if (t === "summon")  return "Summon";
        return "";
      }

      function getTypeLabel(unit, modeKey) {
        
        var main = "";
        var tags = [];

        var hasModes = unit && unit.modes && typeof unit.modes === "object";
        if (hasModes) {
          var keys = Object.keys(unit.modes);
          var mk = (modeKey && unit.modes[modeKey]) ? modeKey : (keys[0] || null);

          if (mk && unit.modes[mk]) {
            main = normalizeTypeMain(unit.modes[mk].typeMain || unit.typeMain);

            var mt = unit.modes[mk].typeTags;
            if (Array.isArray(mt)) tags = mt.slice();
            else if (Array.isArray(unit.typeTags)) tags = unit.typeTags.slice();
          }
        } else {
          main = normalizeTypeMain(unit && unit.typeMain);
          if (Array.isArray(unit && unit.typeTags)) tags = unit.typeTags.slice();
        }

        
        var clean = [];
        for (var i = 0; i < tags.length; i++) {
          var tag = normalizeTypeTag(tags[i]);
          if (!tag) continue;
          if (clean.indexOf(tag) === -1) clean.push(tag);
        }

        
        if (!main && clean.length === 0) return "—";
        if (!main) return clean.join(" • ");

        return clean.length ? (main + " • " + clean.join(" • ")) : main;
      }

