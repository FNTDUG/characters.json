      function ueFitContainer(container) {
        if (!container) return;
        if (window.innerWidth <= 768) return;

        var table = container.querySelector("table");
        if (!table) return;

        table.style.transform = "";
        container.style.height = "";

        var available = container.getBoundingClientRect().width;
        var needed = table.getBoundingClientRect().width;

        if (needed <= available) return;

        var scale = (available - 8) / needed;
        if (scale < 0.60) scale = 0.60;

        table.style.transformOrigin = "top center";
        table.style.transform = "scale(" + scale.toFixed(3) + ")";
        container.style.height = (table.offsetHeight * scale) + "px";
