      function ueVDNorm(s) {
        return String(s || "")
          .toLowerCase()
          .replace(/[\u2019]/g, "'")
          .replace(/[^a-z0-9]+/g, " ")
          .trim()
          .replace(/\s+/g, " ");
      }

      function ueVDLoad(cb) {
        if (window.__ueVD.loaded && window.__ueVD.byBaseText) {
          if (typeof cb === "function") cb();
          return;
        }
        if (window.__ueVD.loading) {
          if (typeof cb === "function") cb();
          return;
        }

        window.__ueVD.loading = true;

        fetch("https://fntd2.com/all_units.json", { cache: "no-store" })
          .then(function (r) { return r.json(); })
          .then(function (json) {
            var map = {};
            for (var k in json) {
        if (!Object.prototype.hasOwnProperty.call(json, k)) continue;
        var entry = json[k];
        if (!entry || !entry.baseText) continue;

        
        if (/pet$/i.test(k)) continue;

        var key = ueVDNorm(entry.baseText);
        if (!key) continue;

        
        if (!map[key]) {
          map[key] = entry;
        }
      }

            window.__ueVD.byBaseText = map;
            window.__ueVD.loaded = true;
            window.__ueVD.loading = false;

            if (typeof cb === "function") cb();
          })
          .catch(function (err) {
            console.warn("UE Value/Demand fetch failed:", err);
            window.__ueVD.byBaseText = {};
            window.__ueVD.loaded = true;
            window.__ueVD.loading = false;
            if (typeof cb === "function") cb();
          });
      }

      function ueVDGetForUnit(unitObj) {
        if (!unitObj || !window.__ueVD.byBaseText) return null;

        var key = ueVDNorm(unitObj.name || "");
        if (!key) return null;

        var entry = window.__ueVD.byBaseText[key];
        if (!entry || !entry.variants || !entry.variants.length) return null;

        var wantShiny = (typeof isShinyMode !== "undefined" && !!isShinyMode);
        var idx = (wantShiny && entry.variants.length > 1) ? 1 : 0;

        var v = entry.variants[idx] || entry.variants[0] || null;
        if (!v) return null;

        return {
          value:  (v.value  != null && v.value  !== "") ? v.value  : null,
          demand: (v.demand != null && v.demand !== "") ? v.demand : null,
          state:  (v.state  != null && v.state  !== "") ? v.state  : null
        };
      }

      
      function ueVDAutoFit(el, maxPx, minPx) {
        if (!el) return;
        el.style.fontSize = maxPx + "px";
        el.style.whiteSpace = "nowrap";
        el.style.overflow = "hidden";

        var tries = 0;
        while (tries < 40 && el.scrollWidth > el.clientWidth && maxPx > minPx) {
          maxPx -= 1;
          el.style.fontSize = maxPx + "px";
          tries++;
        }
      }

      
      function ueVDTrendFromState(stateStr) {
        var s = String(stateStr || "").toLowerCase();

        
        if (s.includes("rising") || s.includes("increase")) {
          return { ch: "▲", color: "#6bdc7f" };
        }

        if (s.includes("dropping") || s.includes("decrease")) {
          return { ch: "▼", color: "#e26d6d" };
        }

        return null;
      }

