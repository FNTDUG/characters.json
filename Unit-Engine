              seen[e.toLowerCase()] = e;
            });
            Object.keys(seen).sort().forEach(function(k) {
              opts.push({ value: k, label: seen[k] });
            });
            _valueSel._rebuild(opts);
            _valueSel._set(norm(currentElementFilter || "all"));
          } else if (currentCategoryMode === "type") {
            opts.push({ value: "all", label: "All Types", placeholder: true });
            UE_TYPE_OPTIONS.forEach(function(t) {
              opts.push({ value: norm(t), label: t });
            });
            _valueSel._rebuild(opts);
            _valueSel._set(norm(currentTypeFilter || "all"));
          } else if (currentCategoryMode === "placements") {
            opts.push({ value: "all",  label: "Select...", placeholder: true });
            opts.push({ value: "most", label: "Most" });
            opts.push({ value: "least", label: "Least" });
            _valueSel._rebuild(opts);
            _valueSel._set(currentPlacementsSort || "all");
          }
        }
        
        
        
        
        function unitHasType(u, wanted) {
          wanted = norm(wanted);
          if (!wanted || wanted === "all") return true;

          if (norm(u.typeMain) === wanted) return true;

          var tags = Array.isArray(u.typeTags) ? u.typeTags : [];
          for (var i = 0; i < tags.length; i++) {
            if (norm(tags[i]) === wanted) return true;
          }
          return false;
        }

        
        
        
        function updateDropdown(filter) {
          autocomplete.innerHTML = "";
          var q = norm(filter || "");

          var matches = characters.filter(function (u) {
            var nameMatch = !q || norm(u.name).includes(q);

            var categoryMatch = true;

            if (currentCategoryMode === "rarity") {
        categoryMatch =
          currentRarityFilter === "all" ||
          norm(u.rarity) === norm(currentRarityFilter);

      } else if (currentCategoryMode === "element") {
        categoryMatch =
          currentElementFilter === "all" ||
          norm(u.element) === norm(currentElementFilter);

      } else if (currentCategoryMode === "type") {
        categoryMatch = unitHasType(u, currentTypeFilter);

      }
            

            return nameMatch && categoryMatch;
          });

          matches.sort(function (a, b) {
            if (currentCategoryMode === "placements" && currentPlacementsSort !== "all") {
              var pA = a.placements || 1, pB = b.placements || 1;
              if (pA !== pB) return currentPlacementsSort === "most" ? pB - pA : pA - pB;
            }
            var rDiff = getRarityRank(a.rarity) - getRarityRank(b.rarity);
            if (rDiff !== 0) return rDiff;
            return a.name.localeCompare(b.name);
          });

          if (!matches.length) {
            autocomplete.style.display = "none";
            return;
          }

          var _countEl = document.createElement("div");
          _countEl.className = "ue-ac-count";
          _countEl.textContent = matches.length + (matches.length === 1 ? " UNIT" : " UNITS");
          autocomplete.appendChild(_countEl);

          matches.forEach(function (u) {
            var div = document.createElement("div");
            div.className = "autocomplete-item";
            div.textContent = u.name;

            applyRarityTextStyle(div, u.rarity);

            div.addEventListener("click", function () {
              input.value = u.name;
              autocomplete.style.display = "none";

              allowDisplayAnimation = true;
              shinyToggleTriggered = false;
              currentUnitLevel = 1;
              isShinyMode = false;
              
              if (typeof playUnitSearchSound === "function") playUnitSearchSound();

              if (u.name === "Scarecrow Freddy") {
                scarecrowMode = "raiser";
                displayUnit(u, "raiser");
              } else if (u.name === "Mangle") {
                mangleModeIndex = 0;
                displayUnit(u, null);
              } else {
                if (u.modes && typeof u.modes === "object") {
                  var keys = Object.keys(u.modes);
                  displayUnit(u, keys.length ? keys[0] : null);
                } else {
                  displayUnit(u, null);
                }
              }
            });

            autocomplete.appendChild(div);
          });

          autocomplete.style.display = "block";
        }

        
        
        
        input.addEventListener("input", function () {
          updateDropdown(input.value);
        });

        input.addEventListener("focus", function () {
        input.value = "";
        updateDropdown("");
      });

        
        document.addEventListener("click", function (e) {
          if (e.target !== input && !autocomplete.contains(e.target) &&
              !_modeSel.contains(e.target) && !_valueSel.contains(e.target)) {
            autocomplete.scrollTop = 0;
            autocomplete.style.display = "none";
            if (document.activeElement === input) input.blur();
          }
        });

        
        input.addEventListener("keydown", function (e) {
          if (e.key !== "Enter") return;

          var q = norm(input.value);
          var found = characters.find(function (u) { return norm(u.name) === q; });
          if (!found) return;

          autocomplete.style.display = "none";

          allowDisplayAnimation = true;
          shinyToggleTriggered = false;
          currentUnitLevel = 1;
          isShinyMode = false;
          document.dispatchEvent(new Event("ue-shiny-toggle"));

          if (typeof playUnitSearchSound === "function") playUnitSearchSound();

          if (found.name === "Scarecrow Freddy") {
            scarecrowMode = "raiser";
            displayUnit(found, "raiser");
          } else if (found.name === "Mangle") {
            mangleModeIndex = 0;
            displayUnit(found, null);
          } else {
            if (found.modes && typeof found.modes === "object") {
              var keys = Object.keys(found.modes);
              displayUnit(found, keys.length ? keys[0] : null);
            } else {
              displayUnit(found, null);
            }
          }
        });

        
        rebuildValueSelect();

      (function () {
        function clampHoriz(el) {
          el.addEventListener("scroll", function () {
            if (el.scrollLeft < 0) el.scrollLeft = 0;
            var max = el.scrollWidth - el.clientWidth;
            if (el.scrollLeft > max) el.scrollLeft = max;
          }, { passive: true });
        }

        document.querySelectorAll("#unitEngine .unit-table-container").forEach(function (el) {
          clampHoriz(el);
        });
      })();
        
      })();
          })
          .catch(function(e) {
            result.innerHTML = "";
            var _errMsg = document.createElement("div");
            _errMsg.style.textAlign = "center";
            _errMsg.style.padding = "20px";
            _errMsg.style.color = "#ff4444";
            _errMsg.style.fontSize = "14px";
            _errMsg.textContent = "Failed to load unit data. Please refresh.";
            result.appendChild(_errMsg);
            console.error("Unit Engine: failed to load characters:", e);
          });
      })();
      </script>
