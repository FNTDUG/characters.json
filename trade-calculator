function getFirstGradientColor(grad) {
  var m = grad ? grad.match(/linear-gradient\([^,]+,\s*(#[0-9a-fA-F]+)/) : null;
  return m ? m[1] : "#aaa";
}

function buildRarityFilters() {
  var container = document.getElementById("rarityFilters");
  if (!container) return;

  if (!container.children.length) {
    var order = ["radiant","apex","exclusive","nightmare","secret","mythic","epic","rare","uncommon"];
    var labels = {
      radiant: "Radiant", apex:"Apex", exclusive:"Exclusive", nightmare:"Nightmare",
      secret:"Secret", mythic:"Mythic", epic:"Epic", rare:"Rare", uncommon:"Uncommon"
    };
    for (var i = 0; i < order.length; i++) {
      var r = order[i];
      var st = rarityStyles[r];
      if (!st) continue;
      var grad = st.borderGradient;
      var col = st.tabColor || getFirstGradientColor(grad);
      var btn = document.createElement("div");
      btn.className = "rarity-tab";
      btn.dataset.rarityKey = r;
      btn.dataset.rarityColor = col;
      btn.style.background = grad;

      var inner = document.createElement("div");
      inner.className = "rarity-tab-inner";
      inner.style.backgroundColor = "rgba(8,6,18,0.92)";

      var label = document.createElement("span");
      label.textContent = labels[r];
      label.style.backgroundImage = grad;
      label.style.webkitBackgroundClip = "text";
      label.style.backgroundClip = "text";
      label.style.webkitTextFillColor = "transparent";
      label.style.color = "transparent";
      label.style.display = "inline-block";
      inner.appendChild(label);
      btn.appendChild(inner);

      btn.onclick = function() {
        currentRarityFilter = (currentRarityFilter === this.dataset.rarityKey) ? "all" : this.dataset.rarityKey;
        updateRarityFiltersActive();
        applyDisplayFilters();
      };
      container.appendChild(btn);
    }

    // Champion filter — Units tab only
    var champBtn = document.createElement("div");
    champBtn.className = "rarity-tab";
    champBtn.id = "champRarityBtn";
    champBtn.dataset.rarityKey = "champion";
    champBtn.dataset.rarityColor = "rgb(207,181,59)";
    champBtn.style.background = CHAMPION_GRADIENT;
    champBtn.style.display = currentCat === "Units" ? "" : "none";

    var champInner = document.createElement("div");
    champInner.className = "rarity-tab-inner";
    champInner.style.backgroundColor = "rgba(8,6,18,0.92)";

    var champLabel = document.createElement("span");
