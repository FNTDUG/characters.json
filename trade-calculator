function buildSelector(){
  var list = document.getElementById("unitList");
  list.innerHTML = "";

  var filtered = units.filter(function(u) {
    return (u.category || "Units") === currentCat;
  });

  var sortedUnits = currentCat === "Comments" ? filtered.slice() : filtered.slice().sort(function(a, b) {
    var rA = rarityOrder.indexOf(a.rarity || "default");
    var rB = rarityOrder.indexOf(b.rarity || "default");
    if (rA !== rB) return rA - rB;
    return a.name.localeCompare(b.name);
  });

