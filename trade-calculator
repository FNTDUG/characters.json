function formatValue(n) {
  if (!isFinite(n)) return "0";

  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "m";
  if (n >= 1_000) return (n / 1_000).toFixed(1) + "k";

  return Math.round(n).toString();
}

function formatStackCount(n) {
  if (n >= 1e9) return "x" + (n / 1e9).toFixed(2) + "b";
  if (n >= 1e6) return "x" + (n / 1e6).toFixed(2) + "m";
  if (n >= 1e3) return "x" + (n / 1e3).toFixed(2) + "k";
  return "x" + n;
}

function setStackText(el, n) {
  if (!el) return;
  var t = formatStackCount(n);
  el.textContent = t;
  var mobile = window.innerWidth <= 600;
  var base = mobile ? 7 : 8;
  var size = t.length <= 3 ? base : t.length <= 5 ? base - 1 : base - 2;
  el.style.fontSize = Math.max(6, size) + "px";
}

