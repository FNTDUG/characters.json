var _rblxCache   = {};
var _rblxPending = {};
var _rblxQueue   = [];
var _rblxTimer   = null;

function _rblxExtractId(url) {
  if (!url) return null;
  if (url.startsWith('rbxassetid://')) return url.slice(13);
  var m = url.match(/assetdelivery\.roblox\.com\/v\d+\/asset\/\?id=(\d+)/);
  return m ? m[1] : null;
}

function _rblxResolve(assetId, imgEl) {
  if (_rblxCache[assetId]) { imgEl.src = _rblxCache[assetId]; return; }
  if (!_rblxPending[assetId]) _rblxPending[assetId] = [];
  _rblxPending[assetId].push(imgEl);
  if (_rblxQueue.indexOf(assetId) === -1) _rblxQueue.push(assetId);
  clearTimeout(_rblxTimer);
  _rblxTimer = setTimeout(_rblxFlush, 60);
}

function _rblxFlush() {
  if (!_rblxQueue.length) return;
  var batch = _rblxQueue.splice(0, 100);
  fetch('https://thumbnails.roblox.com/v1/assets?assetIds=' + batch.join(',') + '&size=420x420&format=Png')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      (data.data || []).forEach(function(item) {
        var id  = String(item.targetId);
        var url = item.imageUrl;
        if (!url) return;
        _rblxCache[id] = url;
        (_rblxPending[id] || []).forEach(function(el) { el.src = url; });
        delete _rblxPending[id];
      });
      if (_rblxQueue.length) _rblxFlush();
    })
    .catch(function() {});
}

