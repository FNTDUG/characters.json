function updateRarityFiltersActive() {
  var container = document.getElementById("rarityFilters");
  if (!container) return;
  container.querySelectorAll(".rarity-tab").forEach(function(btn) {
    var isActive = btn.dataset.rarityKey === currentRarityFilter;
    btn.classList.toggle("active", isActive);
    var col = btn.dataset.rarityColor || "";
