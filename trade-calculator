function ueAutoFitTable(container) {
  if (!container) return;

  if (window.innerWidth < 769) {
    var table = container.querySelector("table");
    if (table) {
      table.style.fontSize = "";
      table.style.width = "max-content"; // allow scroll on mobile
    }
    return;
  }

  var table = container.querySelector("table");
  if (!table) return;

  table.style.fontSize = "";
  table.style.width = "auto";

  var parentWidth = container.clientWidth;
  var tableWidth  = table.scrollWidth;

  if (tableWidth <= parentWidth) return;

  var scale = parentWidth / tableWidth;
  var newFont = Math.max(10, Math.floor(14 * scale));
  table.style.fontSize = newFont + "px";

  var cells = table.querySelectorAll("th, td");
  cells.forEach(function(cell) {
    cell.style.padding = (Math.max(4, 8 * scale)).toFixed(1) + "px " +
                         (Math.max(3, 6 * scale)).toFixed(1) + "px";
  });

  table.style.width = "100%";
 }
  
