var _EK=["none","haywire","phantom","blighted","springlocked","shadow","vengeance","investor","engineer","puppet_nm","scooped","hijacked","champion"];

function generateLink(){
  var enc=function(items){
    return items.map(function(i){
      var ui=units.findIndex(function(u){return u.name===i.name&&(u.type||"")===(i.type||"");});
      var ei=_EK.indexOf(i.enchant||"none");
      return[ui<0?i.name:ui,i.shiny?1:0,ei<0?0:ei,i.count||1,i.glitched?1:0,i.customValue||"",i.level||0];
    });
  };
  var soulM=document.getElementById("mySoulBar").value||"0";
  var soulT=document.getElementById("theirSoulBar").value||"0";
  var payload={m:enc(myItems),t:enc(theirItems)};
  if(soulM!=="0")payload.sm=soulM;
  if(soulT!=="0")payload.st=soulT;
  var compressed=LZString.compressToEncodedURIComponent(JSON.stringify(payload));
  document.getElementById("shareLink").value=location.origin+location.pathname+"#"+compressed;
}

function loadFromURL(){
  var raw=location.hash?location.hash.slice(1):new URLSearchParams(location.search).get("t");
  if(!raw)return;
  var json=LZString.decompressFromEncodedURIComponent(raw);
  if(!json)return;
  var data;try{data=JSON.parse(json);}catch(e){return;}

  myItems=[];theirItems=[];myTotal=0;theirTotal=0;

  function resolveUnit(ref){
    if(typeof ref==="number")return units[ref]||null;
    return units.find(function(u){return u.name===ref;})||null;
  }

  var smEl=document.getElementById("mySoulBar");
  var stEl=document.getElementById("theirSoulBar");
  if(smEl&&data.sm)smEl.value=data.sm;
  if(stEl&&data.st)stEl.value=data.st;

  function bulkLoad(item, side){
    var base=resolveUnit(item[0]);if(!base)return;
    currentSide=side;
    var ench=typeof item[2]==="number"?(_EK[item[2]]||"none"):(item[2]||"none");
    var count=item[3]||1;
    var _cvVal=item[5]||"";
    var lvl=Number(item[6])||0;
    var uobj=Object.assign({},base,{shiny:!!item[1],enchant:ench,glitched:!!item[4],customValue:_cvVal,level:lvl});
    var _prev=detailShiny;
    detailShiny=!!item[1];
    var _vd=ueVDGetForUnit(uobj);
    detailShiny=_prev;
    if(ench==="champion"){
      uobj.value=0;
    } else if(_vd){
      uobj.value=(parseValue(_vd.value||0)||0)+getEnchantValue(_vd,ench);
      uobj.demand=_vd.demand||"";
      uobj.state=_vd.state||"";
    }
    addUnit(uobj);
    if(count>1){
      var lst=side==="my"?myItems:theirItems;
      var ex=lst.find(function(i){return getKey(i)===getKey(uobj);});
      if(ex){
        var extra=count-1;
        ex.count=(ex.count||1)+extra;
        var cel=document.querySelector('[data-id="'+ex.id+'"] .stackCount');
        setStackText(cel, ex.count);
        if(side==="my")myTotal+=(Number(uobj.value)||0)*extra;
        else theirTotal+=(Number(uobj.value)||0)*extra;
      }
    }
  }
  data.m&&data.m.forEach(function(item){bulkLoad(item,"my");});
  data.t&&data.t.forEach(function(item){bulkLoad(item,"their");});
  updateStatus();
}

