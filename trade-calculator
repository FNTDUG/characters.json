    champLabel.style.webkitBackgroundClip = "text";
    champLabel.style.backgroundClip = "text";
    champLabel.style.webkitTextFillColor = "transparent";
    champLabel.style.color = "transparent";
    champLabel.style.display = "inline-block";
    champInner.appendChild(champLabel);
    champBtn.appendChild(champInner);

    champBtn.onclick = function() {
      currentRarityFilter = (currentRarityFilter === "champion") ? "all" : "champion";
      updateRarityFiltersActive();
      applyDisplayFilters();
    };
    container.appendChild(champBtn);
