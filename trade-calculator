  var pdColA = _pdMakeCol("Value",  "ueValueText");
  var pdColB = _pdMakeCol("Demand", "ueDemandText");
  var pdColC = _pdMakeCol("Exists", "ueExistsText");
  pdColC.classList.add("ue-exists-cell");
  pdVdGrid.appendChild(pdColA); pdVdGrid.appendChild(pdColB); pdVdGrid.appendChild(pdColC);
  pdVdInner.appendChild(_pdMakeDiv("33.33%")); pdVdInner.appendChild(_pdMakeDiv("66.66%"));
  pdVdInner.appendChild(pdVdGrid);
  pdVdOuter.appendChild(pdVdInner);
  pdVdWrap.appendChild(pdVdOuter);
  pdWrapper.appendChild(pdVdWrap);

  function _pdApplyDemand(vd) {
    pdVdWrap.style.display = "block";
    var _dm = { unstable:"rgba(150,95,20,0.92)", stable:"rgba(70,110,140,0.92)", rising:"rgba(45,120,45,0.92)", dropping:"rgba(130,45,45,0.92)", hyped:"rgba(120,55,85,0.92)", overpaid:"rgba(208,97,199,0.92)", underpaid:"rgba(0,180,170,0.92)", manipulated:"rgba(220,140,0,0.92)", fluctuating:"rgba(100,100,100,0.92)" };
    pdVdInner.style.transition = "background-color 0.25s ease";
    if (!vd || !vd.state) { pdVdInner.style.backgroundColor = "rgba(20,15,40,0.88)"; return; }
    var _d = vd.state.toLowerCase().replace(/[^a-z]/g,"");
    var _bg = "rgba(20,15,40,0.88)";
    for (var _k in _dm) { if (_d.includes(_k)) { _bg = _dm[_k]; break; } }
    pdVdInner.style.backgroundColor = _bg;
  }

  ueUpdateValueDemandPanel(unit, pdWrapper, rs);
  _pdApplyDemand(ueVDGetForUnit(unit));
  ueVDLoad(function() {
    if (selectedUnit !== unit) return;
    ueUpdateValueDemandPanel(unit, pdWrapper, rs);
    _pdApplyDemand(ueVDGetForUnit(unit));
  });

  // Rewards
  var rewards = unit.rewards || [];
  if (rewards.length) {
    var isBundle = !!unit.bundle;
    var totalWeight = isBundle ? 100 : rewards.reduce(function(s,r){ return s + (r.weight || 0); }, 0);

    var label = document.createElement("div");
    label.style.cssText = "font-size:9px;color:#ffa45b;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px;padding-bottom:5px;border-bottom:1px solid rgba(255,164,91,0.2);";
    label.textContent = isBundle ? "Guaranteed Contents" : "Possible Rewards";
    body.appendChild(label);

    rewards.forEach(function(r) {
      var pct = isBundle ? null : (totalWeight > 0 ? (r.weight / totalWeight * 100) : 0);
      var row = document.createElement("div");
      row.style.cssText = "display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.07);gap:10px;";

      var left = document.createElement("div");
      left.style.cssText = "display:flex;flex-direction:column;gap:3px;min-width:0;";

      var rName = document.createElement("div");
      rName.style.cssText = "font-size:9px;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;";
      rName.textContent = r.name;

      var rType = document.createElement("div");
      rType.style.cssText = "font-size:7px;color:rgba(255,164,91,0.7);";
      rType.textContent = r.type + (r.amount > 1 ? " ×" + r.amount : "");

      left.appendChild(rName); left.appendChild(rType);

      var right = document.createElement("div");
      right.style.cssText = "font-size:9px;white-space:nowrap;flex-shrink:0;";
      if (isBundle) {
        right.style.color = "#6fc77f";
        right.textContent = "Guaranteed";
      } else {
        var p = pct;
        right.style.color = p >= 50 ? "#6fc77f" : p >= 10 ? "#ffc84d" : p >= 1 ? "#ff8c00" : "#ff5757";
        right.textContent = p >= 0.01 ? p.toFixed(p < 1 ? 2 : p < 10 ? 1 : 1) + "%" : "<0.01%";
      }

      row.appendChild(left); row.appendChild(right);
      body.appendChild(row);
    });
  }

  // Custom value input for presents with no VD value
  var _pdVdCheck = ueVDGetForUnit(unit);
  var _pdHasValue = _pdVdCheck && _pdVdCheck.value && parseValue(_pdVdCheck.value) > 0;
  var _pdCvInput = null;
  if (!_pdHasValue) {
    var _pdCvWrap = document.createElement("div");
    _pdCvWrap.style.cssText = "width:90%;margin:12px auto 0;";
    _pdCvInput = document.createElement("input");
    _pdCvInput.type = "text";
    _pdCvInput.placeholder = "Input Asking Value";
    _pdCvInput.style.cssText = "width:100%;box-sizing:border-box;padding:10px;font-size:16px;text-align:center;background:rgba(8,6,18,0.92);border:2px solid rgba(255,164,91,0.5);border-radius:8px;color:#fff;font-family:'Press Start 2P',cursive;outline:none;transition:border-color 0.15s;";
    _pdCvInput.setAttribute("oninput","this.value=this.value.replace(/[^0-9kmb.]/gi,'')");
    _pdCvInput.addEventListener("focus", function(){ this.style.borderColor="#ffa45b"; });
    _pdCvInput.addEventListener("blur",  function(){ this.style.borderColor="rgba(255,164,91,0.5)"; });
    _pdCvWrap.appendChild(_pdCvInput);
    body.appendChild(_pdCvWrap);
  }

  // Add to trade button
  var addBtn = document.createElement("button");
  addBtn.style.cssText = "width:90%;margin-top:16px;padding:10px;border-radius:10px;border:2px solid rgba(255,164,91,0.5);background:rgba(8,6,18,0.92);color:#fff;font-size:12px;cursor:pointer;font-family:'Press Start 2P',cursive;transition:background 0.15s,transform 0.08s;";
  addBtn.textContent = "Add to Trade";
  addBtn.addEventListener("mouseenter", function(){ addBtn.style.background = "rgba(104,31,98,0.35)"; addBtn.style.borderColor = "#ffa45b"; });
  addBtn.addEventListener("mouseleave", function(){ addBtn.style.background = "rgba(8,6,18,0.92)"; addBtn.style.borderColor = "rgba(255,164,91,0.5)"; });
  addBtn.addEventListener("click", function(){
    _currentCustomValue = _pdCvInput ? _pdCvInput.value.trim() : "";
    openAmountPopup();
  });
  body.appendChild(addBtn);

  document.getElementById("unitPopup").style.display = "none";
  document.getElementById("presentDetailPopup").style.display = "block";
  syncScrollLock();
}

function closePresentDetail() {
  document.getElementById("presentDetailPopup").style.display = "none";
  document.getElementById("unitPopup").style.display = "block";
  syncScrollLock();
}

(function(){
  var _app   = document.getElementById("tradeApp");
  var _shown = false;
  var _alarm = null;
  var _wmTxt = (function(){ var t=""; for(var i=0;i<800;i++) t+="!USED INSPECT ELEMENT! "; return t; })();
  var _wmCss = "position:absolute;inset:0;z-index:2147483647;pointer-events:none;overflow:hidden;font-family:'Press Start 2P',cursive;font-size:9px;color:rgba(255,0,0,0.35);line-height:2.2;word-break:break-all;padding:8px;user-select:none;-webkit-user-select:none;display:block;";

  function _playAlarm() {
    if (_alarm) return;
    try {
      _alarm = new Audio("https://www.fntduserguide.com/_downloads/de7d1886735fcdc0176c8671c3b13dcf");
      _alarm.loop = true;
      _alarm.volume = 0.8;
      _alarm.play().catch(function(){});
    } catch(e) {}
  }

  function _stampWatermark() {
    var el = document.getElementById("inspectWatermark");
    if (el) {
      el.textContent = _wmTxt;
      el.style.cssText = _wmCss;
    } else {
      var nw = document.createElement("div");
      nw.id = "inspectWatermark";
      nw.textContent = _wmTxt;
      nw.style.cssText = _wmCss;
      if (_app) _app.insertBefore(nw, _app.firstChild);
    }
  }

  function _trigger() {
    if (_shown) return;
    _shown = true;
    _stampWatermark();
    _playAlarm();
  }

  // Re-stamp every second once triggered — deletion just makes it reappear
  setInterval(function() {
    if (_shown) _stampWatermark();
  }, 1000);

  // Only fires when text is directly edited via DevTools
  var _editObs = new MutationObserver(function(muts) {
    for (var i = 0; i < muts.length; i++) {
      if (muts[i].type === "characterData") { _trigger(); return; }
    }
  });
  _editObs.observe(_app, { subtree: true, characterData: true });
})();

</script>
